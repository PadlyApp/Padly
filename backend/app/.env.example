# Supabase Configuration
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_key_here

# Admin API protection - required in X-Admin-Secret header for /api/admin/* routes
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_SECRET=your_strong_random_secret_here

# Phase 3B Group -> Listing serving controls
# Neural ranking is primary serving path.
PADLY_GROUP_NEURAL_RANKING_ENABLED=true
PADLY_GROUP_NEURAL_KILL_SWITCH=false

# Legacy stable matching write controls (default OFF in Phase 3B).
# Turn ON only for emergency rollback.
PADLY_STABLE_GROUP_LISTING_WRITES_ENABLED=false
